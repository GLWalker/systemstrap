			"form-border-radius": "var(--wp--custom--border-radius, .375rem)",
			"form-transition": "border-color .15s ease-in-out, box-shadow .15s ease-in-out",
			"form-focus-border-color": "var(--wp--preset--color--primary-50)",
			"form-valid-color": "var:preset|color|success",
			"form-valid-border-color": "var:preset|color|success",
			"form-invalid-color": "var:preset|color|danger",
			"form-invalid-border-color": "var:preset|color|danger",
			"dropdown-border-width": "1px",
			"dropdown-border-color": "var(--wp--preset--color--border-color)",
			"dropdown-border-radius": "var(--wp--custom--border-radius, .375rem)",
			"badge-font-size": ".75em",
			"badge-font-weight": "var(--wp--custom--font-weight-nav)",
			"badge-padding-x": ".65em",
			"badge-padding-y": ".35em",
			"badge-border-radius": "calc(var(--wp--custom--border-radius) / 1.5)",
			"focus-ring-width": ".25rem",
			"focus-ring-color": "rgba(var(--wp--preset--color--primary-shadow-rgb), 0.25)",
			"disabled-bg": "#e9ecef",
			"disabled-opacity": ".75",
			"disabled-filter": "grayscale(75%) brightness(100%)",
			"offcanvas-bg": "var(--wp--preset--color--base)",
			"offcanvas-text": "var(--wp--preset--color--contrast)",
			"system-ui-surface": "color-mix(in srgb, var(--wp--preset--color--base) 4%, transparent)",
			"system-ui-surface-banner": "color-mix(in srgb, var(--wp--preset--color--base) 6%, transparent)",
			"system-ui-active-bg": "color-mix(in srgb, currentColor 1%, transparent)",
			"system-ui-surface-nested": "transparent",
			"system-ui-border-color": "color-mix(in srgb, currentColor 30%, transparent)",
			"system-ui-list-hover-bg": "color-mix(in srgb, currentColor 10%, transparent)",
			"system-ui-panel-hover-bg": "color-mix(in srgb, currentColor 2%, transparent)",
			"system-ui-backdrop-filter": "none",
			"system-ui-background-image": "none",
			"system-ui-background-image-nested": "none"
