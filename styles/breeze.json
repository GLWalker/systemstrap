{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Breeze Layout",
	"description": "Layout: Tailwind UI aesthetic featuring soft shadows and refined spacing.",
	"settings": {
		"custom": {
			"border-radius": "0.375rem",
			"border-radius-sm": "0.25rem",
			"border-radius-lg": "0.5rem",
			"border-radius-xl": "0.75rem",
			"border-radius-pill": "9999px",
			"btn-border-radius": "0.375rem",
			"form-border-radius": "0.375rem",
			"dropdown-border-radius": "0.375rem",
			"shadow": "var:preset|shadow|md",
			"system-ui-surface": "var:preset|color|base",
			"system-ui-surface-nested": "var:preset|color|transparent",
			"system-ui-background-image": "none",
			"system-ui-border-color": "var:preset|color|border-color",
			"link-color": "var:preset|color|primary",
			"link-hover-color": "color-mix(in srgb, var(--wp--preset--color--primary) 70%, var(--wp--preset--color--contrast))",
			"font-weight-light": "300",
			"font-weight-body": "400",
			"font-weight-button": "600",
			"font-weight-heading": "700",
			"font-weight-nav": "500",
			"font-weight-bold": "700"
		},
		"shadow": {
			"presets": [
				{
					"name": "Small",
					"shadow": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)",
					"slug": "sm"
				},
				{
					"name": "Medium",
					"shadow": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
					"slug": "md"
				},
				{
					"name": "Large",
					"shadow": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
					"slug": "lg"
				},
				{
					"name": "Inset",
					"shadow": "inset 0 2px 4px 0 rgb(0 0 0 / 0.05)",
					"slug": "inset"
				},
				{
					"name": "Dropdown Menu",
					"shadow": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
					"slug": "dropdown-menu"
				},
				{
					"name": "Form Focus",
					"slug": "form-focus",
					"shadow": "var(--wp--preset--shadow--form-control-shadow, none), 0 0 0 2px var(--wp--preset--color--base), 0 0 0 4px var(--wp--preset--color--primary)"
				},
				{
					"name": "Form Shadow",
					"shadow": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
					"slug": "form-control-shadow"
				},
				{
					"name": "Button Resting",
					"slug": "btn-resting",
					"shadow": "0 1px 2px 0 rgb(0 0 0 / 0.05)"
				},
				{
					"name": "Button Hover",
					"slug": "btn-hover",
					"shadow": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)"
				},
				{
					"name": "Button Active",
					"slug": "btn-active",
					"shadow": "inset 0 2px 4px 0 rgb(0 0 0 / 0.05)"
				}
			]
		}
	}
}