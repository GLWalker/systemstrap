{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Vapor Cyberpunk",
	"settings": {
		"custom": {
			"font-family-body": "var:preset|font-family|lato",
			"font-family-heading": "var:preset|font-family|lato",
			"font-family-nav": "var:preset|font-family|lato",
			"font-family-button": "var:preset|font-family|lato",
			"font-family-single-title": "var:preset|font-family|lato",
			"font-weight-light": "300",
			"font-weight-body": "400",
			"font-weight-button": "400",
			"font-weight-heading": "700",
			"font-weight-nav": "700",
			"font-weight-bold": "700",
			"border-radius": "0.15rem",
			"border-radius-sm": "0.05rem",
			"border-radius-lg": "0.5rem",
			"border-radius-xl": "1rem",
			"border-radius-2xl": "2rem",
			"border-width": "1px",
			"btn-border-width": "1px",
			"form-border-width": "1px",
			"form-bg-color": "var(--wp--preset--color--primary-20)",
			"form-text-color": "var(--wp--preset--color--primary-text)",
			"form-focus-border-color": "var(--wp--preset--color--secondary-40)",
			"system-ui-border-color": "var(--wp--preset--color--border-color)",
			"shadow": "0 0.5rem 1rem rgba(0, 0, 0, 0.15)",
			"shadow-sm": "0 0.125rem 0.25rem rgba(0, 0, 0, 0.075)",
			"btn-transform": "none",
			"btn-hover-transform": "none"
		}
	},
	"styles": {
		"elements": {
			"button": {
				"spacing": {
					"padding": {
						"top": "0.375rem",
						"bottom": "0.375rem",
						"left": "0.75rem",
						"right": "0.75rem"
					}
				}
			}
		}
	}
}