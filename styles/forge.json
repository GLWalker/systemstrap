{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Forge Layout",
	"description": "Layout: High-density, structured interface inspired by GitHub Primer Brand.",
	"settings": {
		"custom": {
			"border-radius": "0.375rem",
			"border-radius-sm": "0.25rem",
			"border-radius-lg": "0.375rem",
			"border-radius-pill": "100px",
			"btn-border-radius": "0.375rem",
			"form-border-radius": "0.375rem",
			"dropdown-border-radius": "0.75rem",
			"shadow": "var:preset|shadow|sm",
			"system-ui-surface": "var:preset|color|base",
			"system-ui-surface-nested": "none",
			"system-ui-background-image": "none",
			"system-ui-border-color": "var:preset|color|border-color",
			"link-color": "var:preset|color|primary",
			"link-hover-color": "color-mix(in srgb, var(--wp--preset--color--primary) 70%, var(--wp--preset--color--contrast))",
			"font-weight-light": "300",
			"font-weight-body": "400",
			"font-weight-button": "500",
			"font-weight-heading": "600",
			"font-weight-nav": "500",
			"font-weight-bold": "600"
		},
		"shadow": {
			"presets": [
				{
					"name": "Small",
					"shadow": "0 12px 28px rgba(16, 20, 17, 0.08), 0 8px 16px rgba(16, 20, 17, 0.04)",
					"slug": "sm"
				},
				{
					"name": "Medium",
					"shadow": "0 24px 48px rgba(16, 20, 17, 0.1), 0 12px 24px rgba(16, 20, 17, 0.06)",
					"slug": "md"
				},
				{
					"name": "Large",
					"shadow": "0 32px 64px rgba(16, 20, 17, 0.12), 0 16px 32px rgba(16, 20, 17, 0.08)",
					"slug": "lg"
				},
				{
					"name": "Inset",
					"shadow": "inset 0 1px 0 rgba(182, 191, 184, 0.2)",
					"slug": "inset"
				},
				{
					"name": "Dropdown Menu",
					"shadow": "0 24px 48px rgba(16, 20, 17, 0.1), 0 12px 24px rgba(16, 20, 17, 0.06)",
					"slug": "dropdown-menu"
				},
				{
					"name": "Form Focus",
					"slug": "form-focus",
					"shadow": "0 0 0 3px rgba(26, 97, 254, 0.4)"
				},
				{
					"name": "Form Shadow",
					"shadow": "inset 0 1px 0 rgba(182, 191, 184, 0.2)",
					"slug": "form-control-shadow"
				},
				{
					"name": "Button Resting",
					"slug": "btn-resting",
					"shadow": "0 1px 0 rgba(16, 20, 17, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.25)"
				},
				{
					"name": "Button Hover",
					"slug": "btn-hover",
					"shadow": "0 1px 0 rgba(16, 20, 17, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.25)"
				},
				{
					"name": "Button Active",
					"slug": "btn-active",
					"shadow": "inset 0 1px 0 rgba(182, 191, 184, 0.2)"
				}
			]
		},
		"spacing": {
			"spacingSizes": [
				{
					"name": "Ten",
					"size": "0.25rem",
					"slug": "10"
				},
				{
					"name": "Twenty",
					"size": "0.5rem",
					"slug": "20"
				},
				{
					"name": "Thirty",
					"size": "1rem",
					"slug": "30"
				},
				{
					"name": "Forty",
					"size": "1.5rem",
					"slug": "40"
				},
				{
					"name": "Fifty",
					"size": "2rem",
					"slug": "50"
				},
				{
					"name": "Sixty",
					"size": "2.5rem",
					"slug": "60"
				},
				{
					"name": "Seventy",
					"size": "clamp(4rem, 4vw, 7rem)",
					"slug": "70"
				},
				{
					"name": "Eighty",
					"size": "clamp(6rem, 6vw, 10rem)",
					"slug": "80"
				}
			]
		}
	}
}