{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Quartz",
	"settings": {
		"custom": {
			"border-radius": ".375rem",
			"border-radius-sm": ".25rem",
			"border-radius-lg": ".5rem",
			"btn-border-radius": ".375rem",
			"form-border-radius": ".375rem",
			"shadow": "var:preset|shadow|md"
		},
		"shadow": {
			"presets": [
				{
					"name": "Small",
					"shadow": "0 1px 1px rgba(0, 0, 0, 0.1)",
					"slug": "sm"
				},
				{
					"name": "Medium",
					"shadow": "1px 3px 24px -1px rgba(0, 0, 0, 0.15)",
					"slug": "md"
				},
				{
					"name": "Large",
					"shadow": "0 1rem 3rem rgba(0, 0, 0, 0.175)",
					"slug": "lg"
				},
				{
					"name": "Inset",
					"shadow": "inset 0 1px 2px rgba(0, 0, 0, 0.075)",
					"slug": "inset"
				},
				{
					"name": "Dropdown Menu",
					"shadow": "0 1rem 3rem rgba(0, 0, 0, 0.175)",
					"slug": "dropdown-menu"
				},
				{
					"name": "Form Focus",
					"slug": "form-focus",
					"shadow": "var(--wp--preset--shadow--form-control-shadow, none), 0 0 0 .25rem rgba(var(--wp--preset--color--primary-shadow-rgb), 0.5)"
				},
				{
					"name": "Form Shadow",
					"shadow": "inset 0 .0625rem .125rem rgba(0, 0, 0, 0.075)",
					"slug": "form-control-shadow"
				},
				{
					"name": "Button Resting",
					"slug": "btn-resting",
					"shadow": "inset 0 1px 0 rgba(var(--local-btn-highlight-rgb, 255, 255, 255), 0.15), 0 1px 1px rgba(var(--local-btn-shadow-rgb, 0, 0, 0), 0.25)"
				},
				{
					"name": "Button Hover",
					"slug": "btn-hover",
					"shadow": "inset 0 1px 0 rgba(var(--local-btn-highlight-rgb, 255, 255, 255), 0.15), 0 1px 1px rgba(var(--local-btn-shadow-rgb, 0, 0, 0), 0.25)"
				},
				{
					"name": "Button Active",
					"slug": "btn-active",
					"shadow": "inset 0 3px 5px rgba(var(--local-btn-shadow-rgb, 0, 0, 0), 0.5)"
				}
			]
		}
	}
}