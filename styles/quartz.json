{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Quartz Layout",
	"settings": {
		"custom": {
			"border-radius": "0.5rem",
			"border-radius-sm": "0.6rem",
			"border-radius-lg": "0.7rem",
			"border-radius-xl": "1rem",
			"border-radius-pill": "50rem",
			"btn-border-radius": "0.5rem",
			"form-border-radius": "0.5rem",
			"dropdown-border-radius": "0.5rem",
			"shadow": "var:preset|shadow|md",
			"system-ui-surface": "rgba(var(--wp--preset--color--contrast-rgb), 0.3)",
			"system-ui-surface-nested": "none",
			"system-ui-surface-banner": "none",
			"system-ui-background-image": "var:preset|gradient|element",
			"system-ui-background-image-nested": "none",
			"system-ui-backdrop-filter": "blur(5px)",
			"system-ui-border-color": "rgba(var(--wp--preset--color--contrast-rgb), 0.2)",
			"font-weight-light": "300",
			"font-weight-body": "400",
			"font-weight-button": "400",
			"font-weight-heading": "700",
			"font-weight-nav": "400",
			"font-weight-bold": "700"
		},
		"shadow": {
			"presets": [
				{
					"name": "Small",
					"shadow": "0 1px 1px rgba(0, 0, 0, 0.1)",
					"slug": "sm"
				},
				{
					"name": "Medium",
					"shadow": "inset 1px 1px rgba(255, 255, 255, 0.2), inset -1px -1px rgba(255, 255, 255, 0.1), 1px 3px 24px -1px rgba(0, 0, 0, 0.15)",
					"slug": "md"
				},
				{
					"name": "Large",
					"shadow": "0 1rem 3rem rgba(0, 0, 0, 0.175)",
					"slug": "lg"
				},
				{
					"name": "Inset",
					"shadow": "inset 0 1px 2px rgba(0, 0, 0, 0.075)",
					"slug": "inset"
				},
				{
					"name": "Dropdown Menu",
					"shadow": "inset 1px 1px rgba(255, 255, 255, 0.2), inset -1px -1px rgba(255, 255, 255, 0.1), 1px 3px 24px -1px rgba(0, 0, 0, 0.15)",
					"slug": "dropdown-menu"
				},
				{
					"name": "Form Focus",
					"slug": "form-focus",
					"shadow": "var(--wp--preset--shadow--form-control-shadow, none), 0 0 0 .25rem rgba(var(--wp--preset--color--primary-rgb), 0.25)"
				},
				{
					"name": "Form Shadow",
					"shadow": "inset 0 1px 2px rgba(0, 0, 0, 0.075)",
					"slug": "form-control-shadow"
				},
				{
					"name": "Button Resting",
					"slug": "btn-resting",
					"shadow": "inset 0 1px 0 rgba(var(--local-btn-highlight-rgb, 255, 255, 255), 0.15), 0 1px 1px rgba(var(--local-btn-shadow-rgb, 0, 0, 0), 0.25)"
				},
				{
					"name": "Button Hover",
					"slug": "btn-hover",
					"shadow": "inset 0 1px 0 rgba(var(--local-btn-highlight-rgb, 255, 255, 255), 0.15), 0 1px 1px rgba(var(--local-btn-shadow-rgb, 0, 0, 0), 0.25)"
				},
				{
					"name": "Button Active",
					"slug": "btn-active",
					"shadow": "inset 0 3px 5px rgba(var(--local-btn-shadow-rgb, 0, 0, 0), 0.5)"
				}
			]
		}
	}
}