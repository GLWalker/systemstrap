{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Brite Layout",
	"settings": {
		"custom": {
			"border-radius": "0.375rem",
			"border-radius-sm": "0.25rem",
			"border-radius-lg": "0.5rem",
			"border-radius-xl": "1rem",
			"border-radius-pill": "50rem",
			"btn-border-radius": "0.375rem",
			"form-border-radius": "0.375rem",
			"dropdown-border-radius": "0.375rem",
			"border-width": "2px",
			"btn-border-width": "2px",
			"form-border-width": "2px",
			"btn-border-color": "var(--wp--preset--color--border-color)",
			"btn-hover-border-color": "var(--wp--preset--color--border-color)",
			"form-border-color": "var(--wp--preset--color--border-color)",
			"shadow": "var:preset|shadow|md",
			"btn-transform": "translate(-3px, -3px)",
			"btn-hover-transform": "translate(0, 0)",
			"btn-transition": "all 0.3s",
			"system-ui-surface": "#ffffff",
			"system-ui-surface-nested": "none",
			"system-ui-background-image": "var:preset|gradient|element",
			"system-ui-border-color": "#000000",
			"font-weight-light": "300",
			"font-weight-body": "400",
			"font-weight-button": "500",
			"font-weight-heading": "500",
			"font-weight-nav": "500",
			"font-weight-bold": "700"
		},
		"shadow": {
			"presets": [
				{
					"name": "Small",
					"shadow": "1px 1px 0 0 var(--wp--preset--color--border-color)",
					"slug": "sm"
				},
				{
					"name": "Medium",
					"shadow": "3px 3px 0 0 var(--wp--preset--color--border-color)",
					"slug": "md"
				},
				{
					"name": "Large",
					"shadow": "5px 5px 0 0 var(--wp--preset--color--border-color)",
					"slug": "lg"
				},
				{
					"name": "Inset",
					"shadow": "inset 0 1px 2px rgba(0, 0, 0, 0.075)",
					"slug": "inset"
				},
				{
					"name": "Dropdown Menu",
					"shadow": "3px 3px 0 0 var(--wp--preset--color--border-color)",
					"slug": "dropdown-menu"
				},
				{
					"name": "Form Focus",
					"slug": "form-focus",
					"shadow": "var(--wp--preset--shadow--form-control-shadow, none), 3px 3px 0 0 var(--wp--preset--color--border-color)"
				},
				{
					"name": "Form Shadow",
					"shadow": "inset 0 .0625rem .125rem rgba(0, 0, 0, 0.075)",
					"slug": "form-control-shadow"
				},
				{
					"name": "Button Resting",
					"slug": "btn-resting",
					"shadow": "3px 3px 0 0 var(--wp--preset--color--border-color)"
				},
				{
					"name": "Button Hover",
					"slug": "btn-hover",
					"shadow": "none"
				},
				{
					"name": "Button Active",
					"slug": "btn-active",
					"shadow": "none"
				}
			]
		}
	},
	"styles": {
		"elements": {
			"button": {
				"css": "& { margin: 3px 0 0 3px; }"
			}
		}
	}
}