{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Sketchy Layout",
	"settings": {
		"custom": {
			"border-radius": "255px 25px 225px 25px / 25px 225px 25px 255px",
			"border-radius-sm": "255px 25px 225px 25px / 25px 225px 25px 255px",
			"border-radius-lg": "55px 225px 15px 25px / 25px 25px 35px 355px",
			"border-radius-xl": "55px 225px 15px 25px / 25px 25px 35px 355px",
			"border-radius-pill": "50rem",
			"btn-border-radius": "var(--wp--custom--border-radius, 255px 25px 225px 25px / 25px 225px 25px 255px)",
			"form-border-radius": "var(--wp--custom--border-radius, 255px 25px 225px 25px / 25px 225px 25px 255px)",
			"dropdown-border-radius": "var(--wp--custom--border-radius, 255px 25px 225px 25px / 25px 225px 25px 255px)",
			"shadow": "none",
			"system-ui-surface": "var:preset|color|base",
			"system-ui-surface-nested": "none",
			"system-ui-background-image": "none",
			"system-ui-border-color": "var:preset|color|border-color",
			"font-weight-light": "300",
			"font-weight-body": "400",
			"font-weight-button": "400",
			"font-weight-heading": "400",
			"font-weight-nav": "400",
			"font-weight-bold": "700"
		},
		"shadow": {
			"presets": [
				{
					"name": "Small",
					"shadow": "0 0.125rem 0.25rem rgba(0, 0, 0, 0.075)",
					"slug": "sm"
				},
				{
					"name": "Medium",
					"shadow": "0 0.5rem 1rem rgba(0, 0, 0, 0.15)",
					"slug": "md"
				},
				{
					"name": "Large",
					"shadow": "0 1rem 3rem rgba(0, 0, 0, 0.175)",
					"slug": "lg"
				},
				{
					"name": "Inset",
					"shadow": "inset 0 1px 2px rgba(0, 0, 0, 0.075)",
					"slug": "inset"
				},
				{
					"name": "Dropdown Menu",
					"shadow": "0 0.5rem 1rem rgba(0, 0, 0, 0.15)",
					"slug": "dropdown-menu"
				},
				{
					"name": "Form Focus",
					"slug": "form-focus",
					"shadow": "var(--wp--preset--shadow--form-control-shadow, none), 0 0 0 0.25rem rgba(var(--wp--preset--color--primary-rgb), 0.25)"
				},
				{
					"name": "Form Shadow",
					"shadow": "inset 0 1px 2px rgba(0, 0, 0, 0.075)",
					"slug": "form-control-shadow"
				},
				{
					"name": "Button Resting",
					"slug": "btn-resting",
					"shadow": "none"
				},
				{
					"name": "Button Hover",
					"slug": "btn-hover",
					"shadow": "none"
				},
				{
					"name": "Button Active",
					"slug": "btn-active",
					"shadow": "inset 0 3px 5px rgba(0, 0, 0, 0.125)"
				}
			]
		}
	},
	"styles": {
		"elements": {
			"button": {
				"css": "& { border-width: 2px !important; border-style: solid !important; }"
			}
		}
	}
}
