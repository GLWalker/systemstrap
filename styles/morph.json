{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Morph Layout",
	"settings": {
		"custom": {
			"border-radius": "0.5rem",
			"border-radius-sm": "0.25rem",
			"border-radius-lg": "0.75rem",
			"border-radius-xl": "1rem",
			"border-radius-pill": "50rem",
			"btn-border-radius": "var(--wp--custom--border-radius, 0.5rem)",
			"form-border-radius": "var(--wp--custom--border-radius, 0.5rem)",
			"dropdown-border-radius": "var(--wp--custom--border-radius, 0.5rem)",
			"shadow": "var:preset|shadow|sm",
			"system-ui-surface": "var:preset|color|base",
			"system-ui-surface-nested": "none",
			"system-ui-background-image": "none",
			"system-ui-border-color": "var:preset|color|border-color",
			"font-weight-light": "300",
			"font-weight-body": "400",
			"font-weight-button": "600",
			"font-weight-heading": "700",
			"font-weight-nav": "600",
			"font-weight-bold": "700"
		},
		"shadow": {
			"presets": [
				{
					"name": "Small",
					"shadow": "5px 5px 10px rgba(60, 98, 144, 0.2), -5px -5px 10px rgba(255, 255, 255, 0.4)",
					"slug": "sm"
				},
				{
					"name": "Medium",
					"shadow": "5px 5px 10px rgba(60, 98, 144, 0.2), -5px -5px 10px rgba(255, 255, 255, 0.4)",
					"slug": "md"
				},
				{
					"name": "Large",
					"shadow": "8px 8px 40px rgba(0, 0, 0, 0.15)",
					"slug": "lg"
				},
				{
					"name": "Inset",
					"shadow": "inset 2px 3px 6px rgba(0, 0, 0, 0.2), inset -3px -2px 6px rgba(255, 255, 255, 0.2)",
					"slug": "inset"
				},
				{
					"name": "Dropdown Menu",
					"shadow": "5px 5px 10px rgba(60, 98, 144, 0.2), -5px -5px 10px rgba(255, 255, 255, 0.4)",
					"slug": "dropdown-menu"
				},
				{
					"name": "Form Focus",
					"slug": "form-focus",
					"shadow": "var(--wp--preset--shadow--form-control-shadow, none), 0 0 0 0.25rem rgba(var(--wp--preset--color--primary-rgb), 0.25)"
				},
				{
					"name": "Form Shadow",
					"shadow": "inset 2px 3px 6px rgba(0, 0, 0, 0.1), inset -3px -2px 6px rgba(255, 255, 255, 0.1)",
					"slug": "form-control-shadow"
				},
				{
					"name": "Button Resting",
					"slug": "btn-resting",
					"shadow": "5px 5px 10px rgba(60, 98, 144, 0.2), -5px -5px 10px rgba(255, 255, 255, 0.4)"
				},
				{
					"name": "Button Hover",
					"slug": "btn-hover",
					"shadow": "5px 5px 10px rgba(60, 98, 144, 0.2), -5px -5px 10px rgba(255, 255, 255, 0.4)"
				},
				{
					"name": "Button Active",
					"slug": "btn-active",
					"shadow": "inset 2px 3px 6px rgba(0, 0, 0, 0.2), inset -3px -2px 6px rgba(255, 255, 255, 0.2)"
				}
			]
		}
	},
	"styles": {
		"elements": {
			"button": {
				"css": "& { border: none !important; box-shadow: var(--wp--preset--shadow--btn-resting); transition: background-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out, color 0.15s ease-in-out; }\n&:hover { box-shadow: var(--wp--preset--shadow--btn-resting); }\n&:active { box-shadow: var(--wp--preset--shadow--btn-active); }"
			}
		}
	}
}
