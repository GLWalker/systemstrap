{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Twenty Layout",
	"description": "Layout: A classic blogging aesthetic",
	"settings": {
		"custom": {
			"border-radius": "0.375rem",
			"border-radius-sm": "0.25rem",
			"border-radius-lg": "0.5rem",
			"border-radius-xl": "0.75rem",
			"border-radius-pill": "50rem",
			"btn-border-radius": "0.375rem",
			"form-border-radius": "0.375rem",
			"dropdown-border-radius": "0.375rem",
			"shadow": "var:preset|shadow|sm",
			"system-ui-surface": "var:preset|color|base",
			"system-ui-surface-nested": "none",
			"system-ui-background-image": "none",
			"system-ui-list-hover-bg": "color-mix(in srgb, currentColor 5%, transparent)",
			"font-weight-button": "500",
			"font-weight-heading": "700",
			"font-weight-nav": "500",
			"link-color": "var:preset|color|danger",
			"link-hover-color": "color-mix(in srgb, var(--wp--custom--link-color) 70%, var(--wp--preset--color--contrast))"
		},
		"shadow": {
			"presets": [
				{
					"name": "Small",
					"shadow": "0 1px 0 rgba(27, 31, 36, 0.04)",
					"slug": "sm"
				},
				{
					"name": "Medium",
					"shadow": "0 3px 6px rgba(27, 31, 36, 0.15)",
					"slug": "md"
				},
				{
					"name": "Large",
					"shadow": "0 8px 24px rgba(27, 31, 36, 0.15)",
					"slug": "lg"
				},
				{
					"name": "Inset",
					"shadow": "inset 0 1px 0 rgba(208, 215, 222, 0.2)",
					"slug": "inset"
				},
				{
					"name": "Dropdown Menu",
					"shadow": "0 8px 24px rgba(27, 31, 36, 0.15)",
					"slug": "dropdown-menu"
				},
				{
					"name": "Form Focus",
					"slug": "form-focus",
					"shadow": "0 0 0 3px rgba(9, 105, 218, 0.3)"
				},
				{
					"name": "Form Shadow",
					"shadow": "inset 0 1px 0 rgba(208, 215, 222, 0.2)",
					"slug": "form-control-shadow"
				},
				{
					"name": "Button Resting",
					"slug": "btn-resting",
					"shadow": "0 1px 0 rgba(27, 31, 36, 0.1)"
				},
				{
					"name": "Button Hover",
					"slug": "btn-hover",
					"shadow": "0 1px 0 rgba(27, 31, 36, 0.1)"
				},
				{
					"name": "Button Active",
					"slug": "btn-active",
					"shadow": "inset 0 0.15rem 0.3rem rgba(27, 31, 36, 0.15)"
				}
			]
		},
		"spacing": {
			"spacingSizes": [
				{
					"name": "Ten",
					"size": "0.25rem",
					"slug": "10"
				},
				{
					"name": "Twenty",
					"size": "0.5rem",
					"slug": "20"
				},
				{
					"name": "Thirty",
					"size": "1rem",
					"slug": "30"
				},
				{
					"name": "Forty",
					"size": "2rem",
					"slug": "40"
				},
				{
					"name": "Fifty",
					"size": "3rem",
					"slug": "50"
				},
				{
					"name": "Sixty",
					"size": "5rem",
					"slug": "60"
				},
				{
					"name": "Seventy",
					"size": "clamp(4rem, 4vw, 7rem)",
					"slug": "70"
				},
				{
					"name": "Eighty",
					"size": "clamp(6rem, 6vw, 10rem)",
					"slug": "80"
				}
			]
		}
	}
}