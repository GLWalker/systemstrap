{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Roboto & Nunito",
	"settings": {
		"custom": {
			"font-family--body": "var:preset|font-family|roboto",
			"font-family--heading": "var:preset|font-family|nunito-sans"
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var:preset|font-family|roboto"
		},
		"blocks": {
			"core/heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|nunito-sans"
				}
			}
		}
	}
}
