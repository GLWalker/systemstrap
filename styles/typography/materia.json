{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Materia Typography",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Roboto, -apple-system, BlinkMacSystemFont, \"Segoe UI\", \"Helvetica Neue\", Arial, sans-serif",
					"name": "Body Font",
					"slug": "body",
					"fontFace": [
						{
							"fontFamily": "Roboto",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/roboto/roboto-variable.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Oswald",
					"name": "Heading Font",
					"slug": "heading",
					"fontFace": [
						{
							"fontFamily": "Oswald",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/oswald/oswald-0.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Roboto Slab",
					"name": "Display Font",
					"slug": "display",
					"fontFace": [
						{
							"fontFamily": "Roboto Slab",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/roboto-slab/roboto-slab-0.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Anton",
					"name": "Button Font",
					"slug": "button",
					"fontFace": [
						{
							"fontFamily": "Anton",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/anton/anton-0.woff2"
							]
						}
					]
				}
			]
		}
	}
}
