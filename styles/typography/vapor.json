{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Vapor Typography",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Lato, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", \"Noto Sans\", \"Liberation Sans\", Arial, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\", \"Noto Color Emoji\"",
					"name": "Body Font",
					"slug": "body",
					"fontFace": [
						{
							"fontFamily": "Lato",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/lato/lato-v24-latin-regular.woff2",
								"file:./assets/fonts/lato/lato-v24-latin-regular.woff"
							]
						},
						{
							"fontFamily": "Lato",
							"fontStyle": "italic",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/lato/lato-v24-latin-italic.woff2",
								"file:./assets/fonts/lato/lato-v24-latin-italic.woff"
							]
						},
						{
							"fontFamily": "Lato",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/lato/lato-v24-latin-700.woff2",
								"file:./assets/fonts/lato/lato-v24-latin-700.woff"
							]
						},
						{
							"fontFamily": "Lato",
							"fontStyle": "italic",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/lato/lato-v24-latin-700italic.woff2",
								"file:./assets/fonts/lato/lato-v24-latin-700italic.woff"
							]
						}
					]
				},
				{
					"fontFamily": "Ubuntu, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", \"Noto Sans\", \"Liberation Sans\", Arial, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\", \"Noto Color Emoji\"",
					"name": "Heading Font",
					"slug": "heading",
					"fontFace": [
						{
							"fontFamily": "Ubuntu",
							"fontStyle": "normal",
							"fontWeight": "300",
							"src": [
								"file:./assets/fonts/ubuntu/ubuntu-v20-latin-300.woff2",
								"file:./assets/fonts/ubuntu/ubuntu-v20-latin-300.woff"
							]
						},
						{
							"fontFamily": "Ubuntu",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/ubuntu/ubuntu-v20-latin-regular.woff2",
								"file:./assets/fonts/ubuntu/ubuntu-v20-latin-regular.woff"
							]
						},
						{
							"fontFamily": "Ubuntu",
							"fontStyle": "normal",
							"fontWeight": "500",
							"src": [
								"file:./assets/fonts/ubuntu/ubuntu-v20-latin-500.woff2",
								"file:./assets/fonts/ubuntu/ubuntu-v20-latin-500.woff"
							]
						},
						{
							"fontFamily": "Ubuntu",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/ubuntu/ubuntu-v20-latin-700.woff2",
								"file:./assets/fonts/ubuntu/ubuntu-v20-latin-700.woff"
							]
						}
					]
				},
				{
					"fontFamily": "SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\",\"Courier New\",monospace",
					"name": "Monospace Font",
					"slug": "monospace"
				},
				{
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"name": "Navigation Font",
					"slug": "navigation"
				},
				{
					"fontFamily": "Monoton, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", \"Noto Sans\", \"Liberation Sans\", Arial, sans-serif",
					"name": "Display Font",
					"slug": "display",
					"fontFace": [
						{
							"fontFamily": "Monoton",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/monoton/monoton-v19-latin-regular.woff2",
								"file:./assets/fonts/monoton/monoton-v19-latin-regular.woff"
							]
						}
					]
				},
				{
					"fontFamily": "var(--wp--preset--font-family--navigation)",
					"name": "Button Font",
					"slug": "button"
				},
				{
					"fontFamily": "var(--wp--preset--font-family--display)",
					"name": "Single Title Font",
					"slug": "single-title"
				}
			]
		}
	}
}
