{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Vapor Typography",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Lato, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\"",
					"name": "Body Font",
					"slug": "body",
					"fontFace": [
						{
							"fontFamily": "Lato",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/lato/lato-v24-latin-regular.woff2",
								"file:./assets/fonts/lato/lato-v24-latin-regular.woff"
							]
						},
						{
							"fontFamily": "Lato",
							"fontStyle": "italic",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/lato/lato-v24-latin-italic.woff2",
								"file:./assets/fonts/lato/lato-v24-latin-italic.woff"
							]
						},
						{
							"fontFamily": "Lato",
							"fontStyle": "normal",
							"fontWeight": "700",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/lato/lato-v24-latin-700.woff2",
								"file:./assets/fonts/lato/lato-v24-latin-700.woff"
							]
						},
						{
							"fontFamily": "Lato",
							"fontStyle": "italic",
							"fontWeight": "700",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/lato/lato-v24-latin-700italic.woff2",
								"file:./assets/fonts/lato/lato-v24-latin-700italic.woff"
							]
						}
					]
				},
				{
					"fontFamily": "Syncopate",
					"name": "Heading Font",
					"slug": "heading",
					"fontFace": [
						{
							"fontFamily": "Syncopate",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/syncopate/syncopate-0.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Monoton",
					"name": "Display Font",
					"slug": "display",
					"fontFace": [
						{
							"fontFamily": "Monoton",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/monoton/monoton-v19-latin-regular.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Exo 2",
					"name": "Button Font",
					"slug": "button",
					"fontFace": [
						{
							"fontFamily": "Exo 2",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/exo-2/exo-2-0.woff2"
							]
						}
					]
				}
			]
		}
	}
}
