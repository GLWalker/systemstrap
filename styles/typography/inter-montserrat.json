{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Inter & Montserrat",
	"settings": {
		"custom": {
			"wp--preset--font-family--body": "var:preset|font-family|inter",
			"wp--preset--font-family--heading": "var:preset|font-family|montserrat"
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var:preset|font-family|inter"
		},
		"blocks": {
			"core/heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|montserrat"
				}
			}
		}
	}
}
