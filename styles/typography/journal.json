{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Journal Typography",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\"",
					"name": "Body Font",
					"slug": "body"
				},
				{
					"fontFamily": "\"News Cycle\", \"Arial Narrow Bold\", sans-serif",
					"name": "Heading Font",
					"slug": "heading",
					"fontFace": [
						{
							"fontFamily": "News Cycle",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/news-cycle/newscycle-regular.woff2"
							]
						},
						{
							"fontFamily": "News Cycle",
							"fontStyle": "normal",
							"fontWeight": "700",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/news-cycle/newscycle-bold.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Merriweather",
					"name": "Display Font",
					"slug": "display",
					"fontFace": [
						{
							"fontFamily": "Merriweather",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/merriweather/merriweather-0.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Cardo",
					"name": "Button Font",
					"slug": "button",
					"fontFace": [
						{
							"fontFamily": "Cardo",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/cardo/cardo_normal_400.woff2"
							]
						}
					]
				}
			]
		}
	}
}
