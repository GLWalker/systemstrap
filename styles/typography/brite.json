{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Brite Typography",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", \"Noto Sans\", \"Liberation Sans\", Arial, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\", \"Noto Color Emoji\"",
					"name": "Body Font",
					"slug": "body"
				},
				{
					"fontFamily": "Manrope, sans-serif",
					"name": "Heading Font",
					"slug": "heading",
					"fontFace": [
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/manrope/Manrope-VariableFont_wght.ttf"
							]
						}
					]
				},
				{
					"fontFamily": "Geist, sans-serif",
					"name": "Navigation Font",
					"slug": "navigation",
					"fontFace": [
						{
							"fontFamily": "Geist",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/geist/Geist-VariableFont_wght.ttf"
							]
						}
					]
				},
				{
					"fontFamily": "Syne, sans-serif",
					"name": "Display Font",
					"slug": "display",
					"fontFace": [
						{
							"fontFamily": "Syne",
							"fontWeight": "400 800",
							"fontStyle": "normal",
							"src": [
								"file:./assets/fonts/syne/syne-variable.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace",
					"name": "Monospace Font",
					"slug": "monospace"
				},
				{
					"fontFamily": "var(--wp--preset--font-family--navigation)",
					"name": "Button Font",
					"slug": "button"
				},
				{
					"fontFamily": "var(--wp--preset--font-family--display)",
					"name": "Single Title Font",
					"slug": "single-title"
				}
			]
		}
	}
}
