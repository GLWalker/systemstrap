{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Brite Typography",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", \"Noto Sans\", \"Liberation Sans\", Arial, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\", \"Noto Color Emoji\"",
					"name": "Body Font",
					"slug": "body"
				},
				{
					"fontFamily": "Manrope, sans-serif",
					"name": "Heading Font",
					"slug": "heading",
					"fontFace": [
						{
							"fontFamily": "Manrope",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/manrope/Manrope-VariableFont_wght.ttf"
							]
						}
					]
				},
				{
					"fontFamily": "Syne, sans-serif",
					"name": "Display Font",
					"slug": "display",
					"fontFace": [
						{
							"fontFamily": "Syne",
							"fontWeight": "400 800",
							"fontStyle": "normal",
							"src": [
								"file:./assets/fonts/syne/syne-variable.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Inter",
					"name": "Button Font",
					"slug": "button",
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/inter/Inter-VariableFont_slnt,wght.woff2"
							]
						}
					]
				}
			]
		}
	}
}
