{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Flatly Typography",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Lato, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\"",
					"name": "Body Font",
					"slug": "body",
					"fontFace": [
						{
							"fontFamily": "Lato",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/lato/lato-v24-latin-regular.woff2"
							]
						},
						{
							"fontFamily": "Lato",
							"fontStyle": "normal",
							"fontWeight": "700",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/lato/lato-v24-latin-700.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Jost",
					"name": "Heading Font",
					"slug": "heading",
					"fontFace": [
						{
							"fontFamily": "Jost",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/jost/Jost-VariableFont_wght.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Montserrat",
					"name": "Display Font",
					"slug": "display",
					"fontFace": [
						{
							"fontFamily": "Montserrat",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/montserrat/montserrat-variable.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Open Sans",
					"name": "Button Font",
					"slug": "button",
					"fontFace": [
						{
							"fontFamily": "Open Sans",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/open-sans/open-sans-variable.woff2"
							]
						}
					]
				}
			]
		}
	}
}
