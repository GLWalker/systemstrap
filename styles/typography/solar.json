{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Solar Typography",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "\"Source Sans Pro\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\"",
					"name": "Body Font",
					"slug": "body"
				},
				{
					"fontFamily": "Inconsolata",
					"name": "Heading Font",
					"slug": "heading",
					"fontFace": [
						{
							"fontFamily": "Inconsolata",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/inconsolata/inconsolata-0.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Space Mono",
					"name": "Display Font",
					"slug": "display",
					"fontFace": [
						{
							"fontFamily": "Space Mono",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/space-mono/space-mono-0.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Ubuntu",
					"name": "Button Font",
					"slug": "button",
					"fontFace": [
						{
							"fontFamily": "Ubuntu",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/ubuntu/ubuntu-v20-latin-regular.woff2"
							]
						}
					]
				}
			]
		}
	}
}
