{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Lux Typography",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "\"Nunito Sans\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif",
					"name": "Body Font",
					"slug": "body",
					"fontFace": [
						{
							"fontFamily": "Nunito Sans",
							"fontStyle": "normal",
							"fontWeight": "200 800",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/nunito/nunito-sans-variable.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "\"Nunito Sans\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif",
					"name": "Heading Font",
					"slug": "heading",
					"fontFace": [
						{
							"fontFamily": "Nunito Sans",
							"fontStyle": "normal",
							"fontWeight": "200 800",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/nunito/nunito-sans-variable.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"name": "Navigation Font",
					"slug": "navigation"
				},
				{
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"name": "Display Font",
					"slug": "display"
				},
				{
					"fontFamily": "SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace",
					"name": "Monospace Font",
					"slug": "monospace"
				},
				{
					"fontFamily": "var(--wp--preset--font-family--navigation)",
					"name": "Button Font",
					"slug": "button"
				},
				{
					"fontFamily": "var(--wp--preset--font-family--display)",
					"name": "Single Title Font",
					"slug": "single-title"
				}
			]
		}
	}
}
