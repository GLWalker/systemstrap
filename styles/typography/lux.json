{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Lux Typography",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "\"Nunito Sans\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif",
					"name": "Body Font",
					"slug": "body",
					"fontFace": [
						{
							"fontFamily": "Nunito Sans",
							"fontStyle": "normal",
							"fontWeight": "200 800",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/nunito/nunito-sans-variable.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Playfair Display",
					"name": "Heading Font",
					"slug": "heading",
					"fontFace": [
						{
							"fontFamily": "Playfair Display",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/playfair-display/playfair-display-0.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Cinzel",
					"name": "Display Font",
					"slug": "display",
					"fontFace": [
						{
							"fontFamily": "Cinzel",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/cinzel/cinzel-0.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Merriweather",
					"name": "Button Font",
					"slug": "button",
					"fontFace": [
						{
							"fontFamily": "Merriweather",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/merriweather/merriweather-0.woff2"
							]
						}
					]
				}
			]
		}
	}
}
