{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Minty Typography",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\"",
					"name": "Body Font",
					"slug": "body"
				},
				{
					"fontFamily": "Montserrat, -apple-system, system-ui, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif",
					"name": "Heading Font",
					"slug": "heading",
					"fontFace": [
						{
							"fontFamily": "Montserrat",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/montserrat/montserrat-variable.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Pacifico",
					"name": "Display Font",
					"slug": "display",
					"fontFace": [
						{
							"fontFamily": "Pacifico",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/pacifico/pacifico-0.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Quicksand",
					"name": "Button Font",
					"slug": "button",
					"fontFace": [
						{
							"fontFamily": "Quicksand",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/quicksand/quicksand-0.woff2"
							]
						}
					]
				}
			]
		}
	}
}
