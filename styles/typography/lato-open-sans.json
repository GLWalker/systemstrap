{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Lato & Open Sans",
	"settings": {
		"custom": {
			"wp--preset--font-family--body": "var:preset|font-family|open-sans",
			"wp--preset--font-family--heading": "var:preset|font-family|lato"
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var:preset|font-family|open-sans"
		},
		"blocks": {
			"core/heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|lato"
				}
			}
		}
	}
}
