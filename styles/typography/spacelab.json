{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Spacelab Typography",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "\"Open Sans\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif",
					"name": "Body Font",
					"slug": "body",
					"fontFace": [
						{
							"fontFamily": "Open Sans",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/open-sans/open-sans-variable.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Orbitron",
					"name": "Heading Font",
					"slug": "heading",
					"fontFace": [
						{
							"fontFamily": "Orbitron",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/orbitron/orbitron-0.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Exo 2",
					"name": "Display Font",
					"slug": "display",
					"fontFace": [
						{
							"fontFamily": "Exo 2",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/exo-2/exo-2-0.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Syncopate",
					"name": "Button Font",
					"slug": "button",
					"fontFace": [
						{
							"fontFamily": "Syncopate",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/syncopate/syncopate-0.woff2"
							]
						}
					]
				}
			]
		}
	}
}
