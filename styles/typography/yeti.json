{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Yeti Typography",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "\"Open Sans\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif",
					"name": "Body Font",
					"slug": "body",
					"fontFace": [
						{
							"fontFamily": "Open Sans",
							"fontStyle": "normal",
							"fontWeight": "300 800",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/open-sans/open-sans-variable.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Quicksand",
					"name": "Heading Font",
					"slug": "heading",
					"fontFace": [
						{
							"fontFamily": "Quicksand",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/quicksand/quicksand-0.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Fredoka",
					"name": "Display Font",
					"slug": "display",
					"fontFace": [
						{
							"fontFamily": "Fredoka",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/fredoka/fredoka-0.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Comfortaa",
					"name": "Button Font",
					"slug": "button",
					"fontFace": [
						{
							"fontFamily": "Comfortaa",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/comfortaa/comfortaa-0.woff2"
							]
						}
					]
				}
			]
		}
	}
}
