{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Cerulean Typography",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", \"Noto Sans\", \"Liberation Sans\", Arial, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\", \"Noto Color Emoji\"",
					"name": "Body Font",
					"slug": "body"
				},
				{
					"fontFamily": "Montserrat",
					"name": "Heading Font",
					"slug": "heading",
					"fontFace": [
						{
							"fontFamily": "Montserrat",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/montserrat/montserrat-variable.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Jost",
					"name": "Display Font",
					"slug": "display",
					"fontFace": [
						{
							"fontFamily": "Jost",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/jost/Jost-VariableFont_wght.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Nunito Sans",
					"name": "Button Font",
					"slug": "button",
					"fontFace": [
						{
							"fontFamily": "Nunito Sans",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/nunito/nunito-sans-variable.woff2"
							]
						}
					]
				}
			]
		}
	}
}
