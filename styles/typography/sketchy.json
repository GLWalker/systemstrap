{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Sketchy Typography",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Neucha, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif",
					"name": "Body Font",
					"slug": "body",
					"fontFace": [
						{
							"fontFamily": "Neucha",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/neucha/neucha_normal_400.ttf"
							]
						}
					]
				},
				{
					"fontFamily": "\"Cabin Sketch\", \"Arial Narrow Bold\", sans-serif",
					"name": "Heading Font",
					"slug": "heading",
					"fontFace": [
						{
							"fontFamily": "Cabin Sketch",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/cabin-sketch/cabin-sketch_normal_400.ttf"
							]
						},
						{
							"fontFamily": "Cabin Sketch",
							"fontStyle": "normal",
							"fontWeight": "700",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/cabin-sketch/cabin-sketch_normal_700.ttf"
							]
						}
					]
				},
				{
					"fontFamily": "Permanent Marker",
					"name": "Display Font",
					"slug": "display",
					"fontFace": [
						{
							"fontFamily": "Permanent Marker",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/permanent-marker/permanent-marker-0.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Fredoka",
					"name": "Button Font",
					"slug": "button",
					"fontFace": [
						{
							"fontFamily": "Fredoka",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/fredoka/fredoka-0.woff2"
							]
						}
					]
				}
			]
		}
	}
}
