{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Slate Typography",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", \"Noto Sans\", \"Liberation Sans\", Arial, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\", \"Noto Color Emoji\"",
					"name": "Body Font",
					"slug": "body"
				},
				{
					"fontFamily": "Fjalla One",
					"name": "Heading Font",
					"slug": "heading",
					"fontFace": [
						{
							"fontFamily": "Fjalla One",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/fjalla-one/fjalla-one-0.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Anton",
					"name": "Display Font",
					"slug": "display",
					"fontFace": [
						{
							"fontFamily": "Anton",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/anton/anton-0.woff2"
							]
						}
					]
				},
				{
					"fontFamily": "Oswald",
					"name": "Button Font",
					"slug": "button",
					"fontFace": [
						{
							"fontFamily": "Oswald",
							"fontStyle": "normal",
							"fontWeight": "400",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/oswald/oswald-0.woff2"
							]
						}
					]
				}
			]
		}
	}
}
