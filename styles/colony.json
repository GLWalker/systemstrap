{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Colony Layout",
	"description": "Layout: A highly structured, data-driven enterprise style inspired by Ant Design.",
	"settings": {
		"custom": {
			"border-radius": "0.375rem",
			"border-radius-sm": "0.25rem",
			"border-radius-lg": "0.5rem",
			"border-radius-pill": "50rem",
			"shadow": "var:preset|shadow|sm",
			"system-ui-surface": "var:preset|color|base",
			"system-ui-surface-nested": "none",
			"system-ui-background-image": "none",
			"system-ui-border-color": "var:preset|color|border-color",
			"link-color": "var:preset|color|primary",
			"link-hover-color": "color-mix(in srgb, var(--wp--custom--link-color) 70%, var(--wp--preset--color--base))",
			"font-weight-light": "300",
			"font-weight-body": "400",
			"font-weight-button": "400",
			"font-weight-heading": "600",
			"font-weight-nav": "400",
			"font-weight-bold": "600"
		},
		"shadow": {
			"presets": [
				{
					"name": "Small",
					"shadow": "0 1px 2px 0 rgba(0, 0, 0, 0.05), 0 1px 6px -1px rgba(0, 0, 0, 0.03), 0 2px 4px 0 rgba(0, 0, 0, 0.03)",
					"slug": "sm"
				},
				{
					"name": "Medium",
					"shadow": "0 6px 16px 0 rgba(0, 0, 0, 0.08), 0 3px 6px -4px rgba(0, 0, 0, 0.12), 0 9px 28px 8px rgba(0, 0, 0, 0.05)",
					"slug": "md"
				},
				{
					"name": "Large",
					"shadow": "0 6px 16px 0 rgba(0, 0, 0, 0.08), 0 3px 6px -4px rgba(0, 0, 0, 0.12), 0 9px 28px 8px rgba(0, 0, 0, 0.05)",
					"slug": "lg"
				},
				{
					"name": "Inset",
					"shadow": "inset 0 1px 2px rgba(0, 0, 0, 0.03)",
					"slug": "inset"
				},
				{
					"name": "Dropdown Menu",
					"shadow": "0 6px 16px 0 rgba(0, 0, 0, 0.08), 0 3px 6px -4px rgba(0, 0, 0, 0.12), 0 9px 28px 8px rgba(0, 0, 0, 0.05)",
					"slug": "dropdown-menu"
				},
				{
					"name": "Form Focus",
					"shadow": "0 0 0 2px rgba(22, 119, 255, 0.2)",
					"slug": "form-focus"
				},
				{
					"name": "Form Control Shadow",
					"shadow": "0 0 0 0 transparent",
					"slug": "form-control-shadow"
				},
				{
					"name": "Button Resting",
					"shadow": "0 2px 0 rgba(0, 0, 0, 0.02)",
					"slug": "btn-resting"
				},
				{
					"name": "Button Hover",
					"shadow": "0 2px 0 rgba(0, 0, 0, 0.02)",
					"slug": "btn-hover"
				},
				{
					"name": "Button Active",
					"shadow": "0 0 0 0 transparent",
					"slug": "btn-active"
				}
			]
		},
		"spacing": {
			"spacingSizes": [
				{ "name": "Ten", "size": "0.25rem", "slug": "10" },
				{ "name": "Twenty", "size": "0.5rem", "slug": "20" },
				{ "name": "Thirty", "size": "1rem", "slug": "30" },
				{ "name": "Forty", "size": "1.5rem", "slug": "40" },
				{ "name": "Fifty", "size": "2rem", "slug": "50" },
				{ "name": "Sixty", "size": "3rem", "slug": "60" },
				{ "name": "Seventy", "size": "clamp(4rem, 4vw, 7rem)", "slug": "70" },
				{ "name": "Eighty", "size": "clamp(6rem, 6vw, 10rem)", "slug": "80" }
			]
		}
	}
}
