{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Materia Layout",
	"settings": {
		"custom": {
			"border-radius": "0.375rem",
			"border-radius-sm": "0.25rem",
			"border-radius-lg": "0.5rem",
			"border-radius-xl": "1rem",
			"border-radius-pill": "50rem",
			"btn-border-radius": "var(--wp--custom--border-radius, 0.375rem)",
			"form-border-radius": "var(--wp--custom--border-radius, 0.375rem)",
			"dropdown-border-radius": "var(--wp--custom--border-radius, 0.375rem)",
			"shadow": "var:preset|shadow|sm",
			"system-ui-surface": "var:preset|color|base",
			"system-ui-surface-nested": "none",
			"system-ui-background-image": "var:preset|gradient|element",
			"system-ui-border-color": "var:preset|color|border-color",
			"font-weight-light": "300",
			"font-weight-body": "400",
			"font-weight-button": "500",
			"font-weight-heading": "500",
			"font-weight-nav": "500",
			"font-weight-bold": "700"
		},
		"shadow": {
			"presets": [
				{
					"name": "Small",
					"shadow": "0 1px 4px rgba(0, 0, 0, 0.4)",
					"slug": "sm"
				},
				{
					"name": "Medium",
					"shadow": "0 3px 6px rgba(0, 0, 0, 0.16), 0 3px 6px rgba(0, 0, 0, 0.23)",
					"slug": "md"
				},
				{
					"name": "Large",
					"shadow": "0 10px 20px rgba(0, 0, 0, 0.19), 0 6px 6px rgba(0, 0, 0, 0.23)",
					"slug": "lg"
				},
				{
					"name": "Inset",
					"shadow": "inset 0 1px 2px rgba(0, 0, 0, 0.075)",
					"slug": "inset"
				},
				{
					"name": "Dropdown Menu",
					"shadow": "0 1px 4px rgba(0, 0, 0, 0.3)",
					"slug": "dropdown-menu"
				},
				{
					"name": "Form Focus",
					"slug": "form-focus",
					"shadow": "var(--wp--preset--shadow--form-control-shadow, none), 0 0 0 0.25rem rgba(var(--wp--preset--color--primary-rgb), 0.25)"
				},
				{
					"name": "Form Shadow",
					"shadow": "inset 0 1px 2px rgba(0, 0, 0, 0.075)",
					"slug": "form-control-shadow"
				},
				{
					"name": "Button Resting",
					"slug": "btn-resting",
					"shadow": "0 1px 4px rgba(0, 0, 0, 0.4)"
				},
				{
					"name": "Button Hover",
					"slug": "btn-hover",
					"shadow": "0 3px 6px rgba(0, 0, 0, 0.16), 0 3px 6px rgba(0, 0, 0, 0.23)"
				},
				{
					"name": "Button Active",
					"slug": "btn-active",
					"shadow": "0 10px 20px rgba(0, 0, 0, 0.19), 0 6px 6px rgba(0, 0, 0, 0.23)"
				}
			]
		}
	},
	"styles": {
		"elements": {
			"button": {
				"css": "& { text-transform: uppercase; border: none; box-shadow: var(--wp--preset--shadow--btn-resting); transition: color 0.4s, background-color 0.4s, border-color 0.4s, box-shadow 0.4s; }\n&:hover { box-shadow: var(--wp--preset--shadow--btn-hover); }\n&:active { box-shadow: var(--wp--preset--shadow--btn-active); }"
			}
		}
	}
}