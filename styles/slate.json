{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Slate Layout",
	"settings": {
		"custom": {
			"border-radius": "0.375rem",
			"border-radius-sm": "0.25rem",
			"border-radius-lg": "0.5rem",
			"border-radius-xl": "1rem",
			"border-radius-pill": "50rem",
			"btn-border-radius": "0.375rem",
			"form-border-radius": "0.375rem",
			"dropdown-border-radius": "0.375rem",
			"shadow": "var:preset|shadow|sm",
			"system-ui-surface": "#3a3f44",
			"system-ui-surface-nested": "none",
			"system-ui-background-image": "var:preset|gradient|element",
			"system-ui-border-color": "var:preset|color|border-color",
			"font-weight-light": "300",
			"font-weight-body": "400",
			"font-weight-button": "400",
			"font-weight-heading": "500",
			"font-weight-nav": "400",
			"font-weight-bold": "700"
		},
		"shadow": {
			"presets": [
				{
					"name": "Small",
					"shadow": "0 0.125rem 0.25rem rgba(0, 0, 0, 0.075)",
					"slug": "sm"
				},
				{
					"name": "Medium",
					"shadow": "0 0.5rem 1rem rgba(0, 0, 0, 0.15)",
					"slug": "md"
				},
				{
					"name": "Large",
					"shadow": "0 1rem 3rem rgba(0, 0, 0, 0.175)",
					"slug": "lg"
				},
				{
					"name": "Inset",
					"shadow": "inset 0 1px 2px rgba(0, 0, 0, 0.075)",
					"slug": "inset"
				},
				{
					"name": "Dropdown Menu",
					"shadow": "0 0.5rem 1rem rgba(0, 0, 0, 0.15)",
					"slug": "dropdown-menu"
				},
				{
					"name": "Form Focus",
					"slug": "form-focus",
					"shadow": "var(--wp--preset--shadow--form-control-shadow, none), 0 0 0 .25rem rgba(var(--wp--preset--color--primary-shadow-rgb), 0.25)"
				},
				{
					"name": "Form Shadow",
					"shadow": "inset 0 1px 2px rgba(0, 0, 0, 0.075)",
					"slug": "form-control-shadow"
				},
				{
					"name": "Button Resting",
					"slug": "btn-resting",
					"shadow": "none"
				},
				{
					"name": "Button Hover",
					"slug": "btn-hover",
					"shadow": "none"
				},
				{
					"name": "Button Active",
					"slug": "btn-active",
					"shadow": "none"
				}
			]
		}
	},
	"styles": {
		"elements": {
			"button": {
				"css": "background-image: linear-gradient(180deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 40%, rgba(0,0,0,0.15) 100%); background-blend-mode: overlay;"
			},
			"heading": {
				"css": "text-shadow: -1px -1px 0 rgba(0, 0, 0, 0.3);"
			}
		}
	}
}