{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Capsule Layout",
	"description": "A clean, modern style inspired by flat design principles and the Bulma framework.",
	"settings": {
		"custom": {
			"border-radius": "0.375rem",
			"border-radius-sm": "0.25rem",
			"border-radius-lg": "0.75rem",
			"border-radius-pill": "50rem",
			"shadow": "var:preset|shadow|sm",
			"system-ui-surface": "var:preset|color|base",
			"system-ui-surface-nested": "none",
			"system-ui-background-image": "none",
			"system-ui-border-color": "var:preset|color|border-color",
			"link-color": "var:preset|color|secondary",
			"link-hover-color": "color-mix(in srgb, var(--wp--custom--link-color) 70%, var(--wp--preset--color--contrast))",
			"font-weight-light": "300",
			"font-weight-body": "400",
			"font-weight-button": "600",
			"font-weight-heading": "600",
			"font-weight-nav": "400",
			"font-weight-bold": "700"
		},
		"shadow": {
			"presets": [
				{
					"name": "Small",
					"shadow": "0 0.5em 1em -0.125em rgba(10, 10, 10, 0.1), 0 0 0 1px rgba(10, 10, 10, 0.02)",
					"slug": "sm"
				},
				{
					"name": "Medium",
					"shadow": "0 1em 2em -0.25em rgba(10, 10, 10, 0.1), 0 0 0 1px rgba(10, 10, 10, 0.02)",
					"slug": "md"
				},
				{
					"name": "Large",
					"shadow": "0 1.5em 3em -0.375em rgba(10, 10, 10, 0.1), 0 0 0 1px rgba(10, 10, 10, 0.02)",
					"slug": "lg"
				},
				{
					"name": "Inset",
					"shadow": "inset 0 0.0625em 0.125em rgba(10, 10, 10, 0.05)",
					"slug": "inset"
				},
				{
					"name": "Dropdown Menu",
					"shadow": "0 0.5em 1em -0.125em rgba(10, 10, 10, 0.1), 0 0 0 1px rgba(10, 10, 10, 0.02)",
					"slug": "dropdown-menu"
				},
				{
					"name": "Form Focus",
					"shadow": "0 0 0 0.125em rgba(72, 95, 199, 0.25)",
					"slug": "form-focus"
				},
				{
					"name": "Form Control Shadow",
					"shadow": "inset 0 0.0625em 0.125em rgba(10, 10, 10, 0.05)",
					"slug": "form-control-shadow"
				},
				{
					"name": "Button Resting",
					"shadow": "0 0 0 0 transparent",
					"slug": "btn-resting"
				},
				{
					"name": "Button Hover",
					"shadow": "0 0 0 0 transparent",
					"slug": "btn-hover"
				},
				{
					"name": "Button Active",
					"shadow": "inset 0 1px 3px rgba(10, 10, 10, 0.2)",
					"slug": "btn-active"
				}
			]
		},
		"spacing": {
			"spacingSizes": [
				{ "name": "Ten", "size": "0.25rem", "slug": "10" },
				{ "name": "Twenty", "size": "0.5rem", "slug": "20" },
				{ "name": "Thirty", "size": "0.75rem", "slug": "30" },
				{ "name": "Forty", "size": "1rem", "slug": "40" },
				{ "name": "Fifty", "size": "1.5rem", "slug": "50" },
				{ "name": "Sixty", "size": "3rem", "slug": "60" },
				{ "name": "Seventy", "size": "clamp(4rem, 4vw, 7rem)", "slug": "70" },
				{ "name": "Eighty", "size": "clamp(6rem, 6vw, 10rem)", "slug": "80" }
			]
		}
	}
}
